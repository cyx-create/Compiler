Grammar

    0 $accept: PROG $end

    1 PROG: MAINMETHOD

    2 MAINMETHOD: PUBLIC INT MAIN '(' ')' '{' STMLIST '}'

    3 STMLIST: ε
    4        | STM STMLIST

    5 STM: ID '=' EXP ';'
    6    | RETURN EXP ';'

    7 EXP: '(' EXP ADD EXP ')'
    8    | '(' EXP MINUS EXP ')'
    9    | '(' EXP TIMES EXP ')'
   10    | '(' EXP DIVIDE EXP ')'
   11    | NONNEGATIVEINT
   12    | '(' MINUS EXP ')'
   13    | '(' EXP ')'
   14    | ID

   15 ID: IDENTIFIER


