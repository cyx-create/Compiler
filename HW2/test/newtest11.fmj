public int main() {
  int i;
  int[] a = {6, 3, 0, 5, 9, 1, 2};
  class b1 bo;
  
  i=0;
  bo = new b1();
  bo.bubbleSort(a, length(a));
  while (i < length(a)) {
    putint(a[i]);
    putch(32);
    i = i + 1;
  }
  putch(10);
  return 0;
}

public class b1 {
  int temp;
  public int bubbleSort(int[] array, int size) {
    int i;
    
    i = 0;

    if (size <= 1) {
      return 0;
    }

    while (i < size - 1) {
      if (array[i] > array[i + 1]) {
        temp = array[i];
        array[i] = array[i + 1];
        array[i + 1] = temp;
      }
      i = i + 1;
    }

    return this.bubbleSort(array, size - 1);
  }
}

