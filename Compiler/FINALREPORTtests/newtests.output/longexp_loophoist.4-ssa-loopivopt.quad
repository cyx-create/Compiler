    MOVE_BINOP t51301:int <- (+, t51001:int, t51201:int); 
    MOVE_BINOP t10001:int <- (-, t51301:int, Const:100); 
    EXTCALL putint(t10001:int); 
    EXTCALL putch(Const:10); 
    RETURN Const:0; 
