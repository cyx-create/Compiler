; Generated LLVM IR from Quad representation

declare i8* @malloc(i32)
declare void @free(i8*)

declare i32 @printf(i8*, ...)
declare i32 @__isoc99_scanf(i8*, ...)

declare void @exit(i64)

declare i64 @getint()
declare i64 @getch()
declare i64 @getarray(i64*)
declare void @putint(i64)
declare void @putch(i64)
declare void @putarray(i64, i64*)

define i32 @main() {
entry:
  br label %label_100

label_100:
  %t101010101 = add i64 4, 5
  %t102010101 = add i64 3, %t101010101
  %t103010101 = add i64 2, %t102010101
  %t104010101 = add i64 1, %t103010101
  %t0 = trunc i64 %t104010101 to i32
  ret i32 %t0

  ; Default return
  ret i32 0
}

