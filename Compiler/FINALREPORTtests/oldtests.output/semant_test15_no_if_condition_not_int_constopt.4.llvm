; Generated LLVM IR from Quad representation

declare i8* @malloc(i32)
declare void @free(i8*)

declare i32 @printf(i8*, ...)
declare i32 @__isoc99_scanf(i8*, ...)

declare void @exit(i64)

declare i64 @getint()
declare i64 @getch()
declare i64 @getarray(i64*)
declare void @putint(i64)
declare void @putch(i64)
declare void @putarray(i64, i64*)

define i32 @main() {
entry:
  br label %label_108

label_108:
  %t0 = mul i64 12, 2
  %t1 = trunc i64 %t0 to i32
  %t2 = call i8* @malloc(i32 %t1)
  %t1030101 = ptrtoint i8* %t2 to i64
  %t3 = inttoptr i64 %t1030101 to i64*
  store i64 2, i64* %t3
  %t1000101 = add i64 %t1030101, 0
  %t1080101 = add i64 %t1000101, 0
  %t4 = inttoptr i64 %t1000101 to i64*
  %t1040101 = load i64, i64* %t4
  br label %label_101

label_101:
  %t5 = icmp sge i64 0, %t1040101
  br i1 %t5, label %label_100, label %label_102

label_100:
  call void @exit(i64 -1)
  unreachable

label_102:
  %t6 = mul i64 4, 2
  %t1140101 = add i64 %t1080101, %t6
  %t7 = inttoptr i64 %t1140101 to i64*
  %t1150101 = load i64, i64* %t7
  %t8 = icmp ne i64 %t1150101, 0
  br i1 %t8, label %label_105, label %label_106

label_105:
  %t9 = trunc i64 1 to i32
  ret i32 %t9

label_106:
  br label %label_107

label_107:
  %t10 = trunc i64 0 to i32
  ret i32 %t10

  ; Default return
  ret i32 0
}

