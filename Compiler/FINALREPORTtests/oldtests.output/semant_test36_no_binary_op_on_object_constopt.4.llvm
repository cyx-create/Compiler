; Generated LLVM IR from Quad representation

declare i8* @malloc(i32)
declare void @free(i8*)

declare i32 @printf(i8*, ...)
declare i32 @__isoc99_scanf(i8*, ...)

declare void @exit(i64)

declare i64 @getint()
declare i64 @getch()
declare i64 @getarray(i64*)
declare void @putint(i64)
declare void @putch(i64)
declare void @putarray(i64, i64*)

define i32 @main() {
entry:
  br label %label_105

label_105:
  %t0 = mul i64 4, 2
  %t1 = trunc i64 %t0 to i32
  %t2 = call i8* @malloc(i32 %t1)
  %t10301 = ptrtoint i8* %t2 to i64
  %t10001 = add i64 %t10301, 0
  %t3 = mul i64 4, 2
  %t4 = trunc i64 %t3 to i32
  %t5 = call i8* @malloc(i32 %t4)
  %t10401 = ptrtoint i8* %t5 to i64
  %t10101 = add i64 %t10401, 0
  %t6 = mul i64 0, 2
  %t11001 = add i64 %t10001, %t6
  %t7 = inttoptr i64 %t11001 to i64*
  %t11101 = load i64, i64* %t7
  %t8 = mul i64 0, 2
  %t11201 = add i64 %t10101, %t8
  %t9 = inttoptr i64 %t11201 to i64*
  %t11301 = load i64, i64* %t9
  %t115 = add i64 0, 0
  %t10 = icmp eq i64 %t11101, %t11301
  br i1 %t10, label %label_102, label %label_103

label_102:
  %t114 = add i64 1, 0
  br label %label_103

label_103:
  %t10503 = phi i64 [ %t114, %label_102 ], [ %t115, %label_105 ]
  %t11 = trunc i64 %t10503 to i32
  ret i32 %t11

  ; Default return
  ret i32 0
}

