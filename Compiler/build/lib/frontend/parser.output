Grammar

    0 $accept: PROG $end

    1 PROG: MAINMETHOD CLASSDECLLIST

    2 MAINMETHOD: PUBLIC INT MAIN '(' ')' '{' VARDECLLIST STMLIST '}'

    3 TYPE: CLASS ID
    4     | INT
    5     | INT '[' ']'
    6     | INT '[' NUMBER ']'

    7 VARDECLLIST: ε
    8            | VARDECL VARDECLLIST

    9 VARDECL: TYPE ID ';'
   10        | TYPE ID '=' '{' NUMBERLIST '}' ';'

   11 NUMBER: NONNEGATIVEINT
   12       | MINUS NONNEGATIVEINT

   13 NUMBERLIST: ε
   14           | NUMBER NUMBERREST

   15 NUMBERREST: ε
   16           | ',' NUMBER NUMBERREST

   17 CLASSDECLLIST: ε
   18              | CLASSDECL CLASSDECLLIST

   19 CLASSDECL: PUBLIC CLASS ID '{' VARDECLLIST METHODDECLLIST '}'
   20          | PUBLIC CLASS ID EXTENDS ID '{' VARDECLLIST METHODDECLLIST '}'

   21 METHODDECLLIST: ε
   22               | METHODDECL METHODDECLLIST

   23 METHODDECL: PUBLIC TYPE ID '(' FORMALLIST ')' '{' VARDECLLIST STMLIST '}'

   24 FORMALLIST: ε
   25           | TYPE ID FORMALREST

   26 FORMALREST: ε
   27           | ',' TYPE ID FORMALREST

   28 STMLIST: ε
   29        | STM STMLIST

   30 STM: '{' STMLIST '}'
   31    | IF '(' EXP ')' STM ELSE STM
   32    | IF '(' EXP ')' STM
   33    | WHILE '(' EXP ')' STM
   34    | WHILE '(' EXP ')' ';'
   35    | EXP '=' EXP ';'
   36    | EXP '.' ID '(' EXPLIST ')' ';'
   37    | CONTINUE ';'
   38    | BREAK ';'
   39    | RETURN EXP ';'
   40    | PUTINT '(' EXP ')' ';'
   41    | PUTCH '(' EXP ')' ';'
   42    | PUTARRAY '(' EXP ',' EXP ')' ';'
   43    | STARTTIME '(' ')' ';'
   44    | STOPTIME '(' ')' ';'

   45 EXP: EXP ADD EXP
   46    | EXP MINUS EXP
   47    | EXP TIMES EXP
   48    | EXP DIVIDE EXP
   49    | EXP OR EXP
   50    | EXP AND EXP
   51    | EXP LT EXP
   52    | EXP LE EXP
   53    | EXP GT EXP
   54    | EXP GE EXP
   55    | EXP EQ EXP
   56    | EXP NE EXP
   57    | EXP '[' EXP ']'
   58    | EXP '.' ID '(' EXPLIST ')'
   59    | EXP '.' ID
   60    | NONNEGATIVEINT
   61    | LENGTH '(' EXP ')'
   62    | THIS
   63    | '!' EXP
   64    | MINUS EXP
   65    | '(' EXP ')'
   66    | NEW INT '[' EXP ']'
   67    | NEW ID '(' ')'
   68    | GETINT '(' ')'
   69    | GETCH '(' ')'
   70    | GETARRAY '(' EXP ')'
   71    | ID

   72 EXPLIST: ε
   73        | EXP EXPREST

   74 EXPREST: ε
   75        | ',' EXP EXPREST

   76 ID: IDENTIFIER


