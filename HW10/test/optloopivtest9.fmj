public int main() {
    int i;
    int j;
    int j2;
    int k;
    int a;
    i = getint();
    j = 1;
    j2 = 2;
    k = 10;
    a = 0;
    while (k>0) {
      a = a + 1;
      while (i>0) {
       j = i*a+a;
       putint(j);
       putch(32);
       j2 = i*2+1;
       putint(j2);
       putch(32);
       i = i-1; 
      }
      k = k-1;
    }
    putint(j+j2);
    putch(10);
    return j+j2;
}
