public int main() {
   class A a;
   class B b;
   a = new A();
   a.i = 1;
   b = new B();
   b.i = 1;
   a = b;
   putint(a.f());
}

public class A {
   int i;
   public int f() {}
}

public class B extends A {
   int i;
   public int f() {}
   public int g() {}
}

