public int main() {
    int i;
    int j;
    int j1; 
    int j2;
    int k;
    int a;
    i = getint();
    k = 10;
    a = 0;
    while (k>0) {
      a = a + 1;
      while (i>0) {
       j = 3 * a;
       j1 = j + 4;
       j2 = j1 + 6;
       i = i-1; 
      }
      k = k-1;
    }
    return j;
}
